{
    "name": "signatur",
    "version": "1.2.0",
    "description": "Simple Web App for Signatures",
    "keywords": [
        "html",
        "signatures",
        "vector"
    ],
    "homepage": "https://github.com/hivesolutions/signatur#readme",
    "bugs": {
        "url": "https://github.com/hivesolutions/signatur/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/hivesolutions/signatur.git"
    },
    "license": "Apache-2.0",
    "author": "Hive Solutions",
    "main": "app.js",
    "engines": {
        "node": ">=20"
    },
    "files": [
        "app.js",
        "lib/**/*.js",
        "static/**/*.html",
        "static/**/*.js",
        "test/**/*.js",
        "views/**/*.ejs"
    ],
    "scripts": {
        "build": "node scripts/build.js",
        "icons": "node scripts/icons.js",
        "dev": "nodemon app.js",
        "lint": "eslint \"./**/*.js\"",
        "lint-fix": "eslint \"./**/*.js\" --fix",
        "prettier": "prettier \"./**/*.{js,json}\" --write",
        "pretty": "npm run prettier && npm run lint-fix",
        "prestart": "node scripts/build.js",
        "start": "node app.js",
        "test": "mocha --recursive",
        "upgrade": "npx sort-package-json && ncu -u",
        "user:add": "node scripts/user.js",
        "user:local": "npm run user:add -- user user user && npm run user:add -- admin admin admin"
    },
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "consola": "^3.4.2",
        "cookie-session": "^2.1.1",
        "ejs": "^5.0.2",
        "express": "^5.2.1",
        "express-session": "^1.19.0",
        "hive-js-util": "^0.5.4",
        "jszip": "^3.10.1",
        "multer": "^2.1.1",
        "mustache-express": "^1.3.2",
        "yonius": "^0.14.0"
    },
    "devDependencies": {
        "eslint": "^10.4.0",
        "eslint-config-hive": "^0.7.0",
        "eslint-plugin-n": "^18.0.1",
        "mocha": "^11.7.6",
        "nodemon": "^3.1.14",
        "npm-check-updates": "^22.2.0",
        "prettier": "^3.8.3",
        "prettier-config-hive": "^0.1.7",
        "sharp": "^0.34.5",
        "sort-package-json": "^3.6.1"
    },
    "overrides": {
        "eslint-config-hive": {
            "eslint": "$eslint"
        }
    }
}

        <div class="toast"></div>
        <% if (features.feedback) { %>
            <button class="button-feedback-cta" type="button" title="Enviar opinião" aria-label="Enviar opinião">
                <ion-icon name="chatbubble-ellipses-outline"></ion-icon>
            </button>
        <% } %>
        <div class="modal-overlay modal-overlay-confirm"
             data-label-text="Texto"
             data-label-font="Letra"
             data-label-profile="Perfil"
             data-label-viewport="Área"
             data-label-font-size="Tam. Letra"
             data-label-margins="Margens"
             data-label-extra-padding="Espaç. Extra"
             data-label-final-viewport="Área Final"
             data-label-node="Nó"
             data-label-jig="Suporte"
             data-label-newline="↵"
             data-label-empty="Ainda sem texto — escreva algo no viewport primeiro."
             data-label-ready="Pronto para gravar em">
            <div class="modal modal-confirm">
                <div class="modal-title">Confirmar Gravação</div>
                <div class="modal-subtitle"></div>
                <div class="modal-preview"></div>
                <div class="modal-empty-hint"></div>
                <div class="modal-specs"></div>
                <div class="modal-options">
                    <input class="modal-dry-run option-chip-input" type="checkbox" id="modal-dry-run" />
                    <label class="option-chip option-chip-toggle" for="modal-dry-run">Simulação</label>
                </div>
                <div class="modal-buttons">
                    <span class="button button-modal-engrave">Gravar</span>
                    <span class="button button-ghost button-modal-close">Cancelar</span>
                </div>
            </div>
        </div>
        <div class="modal-overlay modal-overlay-error">
            <div class="modal">
                <div class="modal-message"></div>
                <div class="modal-buttons">
                    <a class="button button-modal-configure" href="/settings">Configurar</a>
                    <span class="button button-modal-close">Fechar</span>
                </div>
            </div>
        </div>
        <div class="modal-overlay modal-overlay-inspirations">
            <div class="modal modal-inspirations">
                <div class="modal-title">Inspirações</div>
                <div class="modal-search">
                    <input class="modal-search-input" type="text" placeholder="Procurar inspirações..." />
                </div>
                <div class="modal-inspirations-grid"></div>
                <div class="modal-buttons">
                    <span class="button button-modal-close">Fechar</span>
                </div>
            </div>
        </div>
        <div class="modal-overlay modal-overlay-instructions">
            <div class="modal modal-instructions">
                <div class="modal-title modal-instructions-title"></div>
                <div class="modal-message modal-instructions-description"></div>
                <div class="modal-instructions-images"></div>
                <div class="modal-buttons">
                    <span class="button button-modal-close">Fechar</span>
                </div>
            </div>
        </div>
        <% if (features.feedback) { %>
            <div class="modal-overlay modal-overlay-feedback">
                <div class="modal modal-feedback">
                    <div class="modal-title">Como correu a gravação?</div>
                    <div class="modal-message">A tua opinião ajuda-nos a melhorar a experiência de gravação.</div>
                    <div class="modal-feedback-group">
                        <div class="modal-feedback-label">Satisfação</div>
                        <div class="option-chips modal-feedback-satisfaction">
                            <input class="option-chip-input" type="radio" id="feedback-very-satisfied" name="feedback_satisfaction" value="very_satisfied" />
                            <label class="option-chip" for="feedback-very-satisfied">Muito Satisfeito</label>
                            <input class="option-chip-input" type="radio" id="feedback-satisfied" name="feedback_satisfaction" value="satisfied" />
                            <label class="option-chip" for="feedback-satisfied">Satisfeito</label>
                            <input class="option-chip-input" type="radio" id="feedback-neutral" name="feedback_satisfaction" value="neutral" />
                            <label class="option-chip" for="feedback-neutral">Neutro</label>
                            <input class="option-chip-input" type="radio" id="feedback-unsatisfied" name="feedback_satisfaction" value="unsatisfied" />
                            <label class="option-chip" for="feedback-unsatisfied">Insatisfeito</label>
                            <input class="option-chip-input" type="radio" id="feedback-very-unsatisfied" name="feedback_satisfaction" value="very_unsatisfied" />
                            <label class="option-chip" for="feedback-very-unsatisfied">Muito Insatisfeito</label>
                        </div>
                    </div>
                    <div class="modal-feedback-group">
                        <div class="modal-feedback-label">Notas (opcional)</div>
                        <textarea class="modal-feedback-notes" rows="3" maxlength="2000" placeholder="Diga-nos o que quiser..."></textarea>
                    </div>
                    <div class="modal-buttons">
                        <span class="button button-modal-feedback-submit disabled">Submeter</span>
                        <span class="button button-ghost button-modal-close">Saltar</span>
                    </div>
                </div>
            </div>
        <% } %>
    </body>
</html>


<!DOCTYPE html>
<html lang="pt">
    <%- include("head"); -%>
    <body class="<%= theme %> <%= viewportMode === 'store' ? 'store-mode' : '' %> profiles-loading" data-theme="<%= theme %>" data-viewport-mode="<%= viewportMode %>" data-master="<%= masterb64 %>" data-message-no-printer="Nenhuma impressora configurada, por favor configure a impressora de gravação nas definições." data-message-pantograph="A letra Cool Emojis Pantograph não é suportada para gravação.">
        <div class="header">
            <div class="buttons-left">
                <a class="button button-small button-back" href="<%= typeof back !== 'undefined' ? back : '/' %>" title="Voltar">
                    <ion-icon name="arrow-back-outline"></ion-icon>
                </a>
                <span class="button button-clear">Limpar</span>
            </div>
            <div class="buttons-right">
                <span class="button button-small button-preview" title="Pré-visualização (Esc para sair)">
                    <ion-icon name="expand-outline"></ion-icon>
                </span>
                <a class="button button-small button-report" href="/report" data-href="/report" title="Relatório">
                    <ion-icon name="document-text-outline"></ion-icon>
                </a>
                <a class="button button-print"
                   data-href="/report"
                   data-url="<%= conf.PRINT_URL %>"
                   data-node="<%= conf.ENGRAVE_NODE %>"
                   data-printer="<%= conf.ENGRAVE_PRINTER %>"
                   data-key="<%= conf.PRINT_KEY %>">Gravar</a>
            </div>
            <% if (theme === "ldj") { %>
                <img class="logo" src="/static/images/logo.svg" />
            <% } else { %>
                <span class="logo"></span>
            <% } %>
        </div>
        <div class="preview-mode-hint">Carregue Esc para sair</div>
        <div class="profile-info collapsible">
            <div class="profile-info-title collapsible-title" data-default-label="Perfil ">Perfil <span class="profile-info-toggle collapsible-toggle">▾</span></div>
            <div class="profile-info-body collapsible-body">
                <div class="profile-info-sku"></div>
                <div class="profile-info-dimensions"></div>
                <div class="profile-info-orientation"></div>
                <div class="profile-info-lines" data-singular="máx {n} linha" data-plural="máx {n} linhas"></div>
                <a class="profile-info-raw-toggle" href="#" data-show-label="Mostrar JSON" data-hide-label="Ocultar JSON">Mostrar JSON</a>
                <pre class="profile-info-raw"></pre>
            </div>
        </div>
        <div class="viewport-options collapsible">
            <div class="viewport-options-title collapsible-title">Opções <span class="viewport-options-toggle collapsible-toggle">▾</span></div>
            <div class="viewport-options-body collapsible-body">
            <div class="viewport-options-field profile-container">
                <label class="viewport-options-label">Perfil</label>
                <select class="profile-select">
                    <option value="">Nenhum</option>
                </select>
            </div>
            <div class="viewport-options-field variant-container">
                <label class="viewport-options-label">Variante</label>
                <select class="variant-select">
                    <option value="">Nenhuma</option>
                </select>
            </div>
            <div class="viewport-options-field slider-field font-size-container">
                <label class="viewport-options-label">Tamanho</label>
                <div class="slider-presets font-size-presets">
                    <span class="slider-preset font-size-preset" data-preset="s">S</span>
                    <span class="slider-preset font-size-preset" data-preset="m">M</span>
                    <span class="slider-preset font-size-preset" data-preset="l">L</span>
                    <span class="slider-preset font-size-preset" data-preset="xl">XL</span>
                    <span class="slider-preset font-size-preset font-size-preset-auto" data-preset="auto">Auto</span>
                </div>
                <div class="slider-track font-size-slider">
                    <input class="slider-range font-size-range" type="range" min="8" max="24" value="12" step="1" />
                    <span class="slider-bubble font-size-bubble">12</span>
                </div>
                <input class="font-size-input" type="hidden" value="12" />
                <input class="font-size-mode" type="checkbox" hidden />
            </div>
            <% if (features.calligraphy) { %>
                <div class="viewport-options-field viewport-options-checkbox calligraphy-mode-container">
                    <label class="viewport-options-option">
                        <input class="calligraphy-mode" type="checkbox" />
                        Modo Caligrafia
                    </label>
                </div>
                <div class="viewport-options-field calligraphy-controls">
                    <span class="button button-small calligraphy-undo">Desfazer</span>
                    <span class="button button-small calligraphy-clear">Limpar</span>
                </div>
                <div class="viewport-options-field slider-field calligraphy-thickness-container">
                    <label class="viewport-options-label">Espessura</label>
                    <div class="slider-presets calligraphy-thickness-presets">
                        <span class="slider-preset calligraphy-thickness-preset" data-preset="1">S</span>
                        <span class="slider-preset calligraphy-thickness-preset" data-preset="2">M</span>
                        <span class="slider-preset calligraphy-thickness-preset" data-preset="4">L</span>
                    </div>
                    <div class="slider-track calligraphy-thickness-slider">
                        <input class="slider-range calligraphy-thickness-range" type="range" min="0.5" max="6" value="2" step="0.25" />
                        <span class="slider-bubble calligraphy-thickness-bubble">2</span>
                    </div>
                </div>
            <% } %>
            <div class="viewport-options-field viewport-options-checkbox viewport-options-rulers">
                <label class="viewport-options-option">
                    <input class="rulers-mode" type="checkbox" checked />
                    Mostrar Réguas
                </label>
            </div>
            <div class="viewport-options-field viewport-options-checkbox viewport-options-crosshair">
                <label class="viewport-options-option">
                    <input class="crosshair-mode" type="checkbox" checked />
                    Mostrar Mira
                </label>
            </div>
            <div class="viewport-options-field viewport-options-checkbox viewport-options-keyboard">
                <label class="viewport-options-option">
                    <input class="keyboard-mode" type="checkbox" checked />
                    Mostrar Teclado
                </label>
            </div>
            <div class="viewport-options-field viewport-options-checkbox viewport-options-guidelines">
                <label class="viewport-options-option">
                    <input class="guidelines-mode" type="checkbox" checked />
                    Mostrar Guias
                </label>
            </div>
            <div class="viewport-options-field viewport-options-checkbox viewport-options-caret">
                <label class="viewport-options-option">
                    <input class="caret-mode" type="checkbox" checked />
                    Mostrar Cursor
                </label>
            </div>
            <div class="viewport-options-field slider-field zoom-container">
                <label class="viewport-options-label">Zoom</label>
                <div class="slider-presets zoom-presets">
                    <span class="slider-preset zoom-preset" data-preset="1">1x</span>
                    <span class="slider-preset zoom-preset" data-preset="2">2x</span>
                    <span class="slider-preset zoom-preset" data-preset="3">3x</span>
                </div>
                <div class="slider-track zoom-slider">
                    <input class="slider-range zoom-range" type="range" min="0.5" max="5" value="1" step="0.5" />
                    <span class="slider-bubble zoom-bubble">1x</span>
                </div>
            </div>
            <div class="viewport-options-field margin-container">
                <label class="viewport-options-label">Margens (mm)</label>
                <div class="margin-fields">
                    <div class="margin-field">
                        <label class="margin-label">Esquerda</label>
                        <input class="margin-input options-input margin-left" type="number" min="0" step="1" value="0" />
                    </div>
                    <div class="margin-field">
                        <label class="margin-label">Direita</label>
                        <input class="margin-input options-input margin-right" type="number" min="0" step="1" value="0" />
                    </div>
                    <div class="margin-field">
                        <label class="margin-label">Topo</label>
                        <input class="margin-input options-input margin-top" type="number" min="0" step="1" value="0" />
                    </div>
                    <div class="margin-field">
                        <label class="margin-label">Fundo</label>
                        <input class="margin-input options-input margin-bottom" type="number" min="0" step="1" value="0" />
                    </div>
                </div>
            </div>
            <div class="viewport-options-field position-container">
                <label class="viewport-options-label">Posição</label>
                <span class="position-value">-</span>
            </div>
            <a class="button button-tiny viewport-options-instructions" href="#">Instruções</a>
            </div>
        </div>
        <div class="inspiration-panel">
            <div class="inspiration-panel-title">Inspirações <span class="inspiration-panel-toggle">▾</span></div>
            <div class="inspiration-panel-body">
                <div class="inspiration-thumbnails"></div>
                <span class="button button-small button-view-all">Ver todas</span>
            </div>
        </div>
        <div class="viewport">
            <div class="main-container">
                <div class="viewport-preview">
                    <div class="ruler ruler-horizontal"></div>
                    <div class="ruler ruler-vertical"></div>
                    <div class="crosshair crosshair-horizontal"></div>
                    <div class="crosshair crosshair-vertical"></div>
                    <svg class="viewport-svg"></svg>
                    <% if (features.calligraphy) { %>
                        <div class="calligraphy-container"></div>
                    <% } %>
                    <div class="viewer-container caret-active" data-text="<%= config.text %>">
                    <% if (text) { %>
                        <% text.forEach(function(item){ %>
                            <% if (item[1] === "\n") { %>
                                <div class="newline"></div>
                            <% } else { %>
                            <span style="font-family: '<%= item[0] %>'"><%- item[1] === " " ? "&nbsp;" : item[1] %></span>
                            <% } %>
                        <% }); %>
                    <% } %>
                    <span class="caret">|</span>
                    </div>
                </div>
                <div class="fonts-container">
                    <% if (!options.fonts || options.fonts.includes("helvetica1l")) { %>
                        <div class="font" data-font="Helvetica 1L" style="font-family: 'Helvetica 1L';">Helvetica 1L</div>
                    <% } %>
                    <% if (!options.fonts || options.fonts.includes("helvetica4l")) { %>
                        <div class="font" data-font="Helvetica 4L" style="font-family: 'Helvetica 4L';">Helvetica 4L</div>
                    <% } %>
                    <% if (!options.fonts || options.fonts.includes("roman4l")) { %>
                        <div class="font" data-font="Roman 4L" style="font-family: 'Roman 4L';">Roman 4L</div>
                    <% } %>
                    <% if (!options.fonts || options.fonts.includes("script4l")) { %>
                        <div class="font" data-font="Script 4L" style="font-family: 'Script 4L';">Script 4L</div>
                    <% } %>
                    <% if (!options.fonts || options.fonts.includes("script4121l")) { %>
                        <div class="font" data-font="Script 412 1L" style="font-family: 'Script 412 1L';">Script 412 1L</div>
                    <% } %>
                    <% if (!options.fonts || options.fonts.includes("scriptround1l")) { %>
                        <div class="font" data-font="Script Round 1L" style="font-family: 'Script Round 1L';">Script Round 1L</div>
                    <% } %>
                    <% if (!options.fonts || options.fonts.includes("coolemojis")) { %>
                        <div class="font" data-font="Cool Emojis" style="font-family: 'Helvetica';">Cool Emojis</div>
                    <% } %>
                    <% if (!options.fonts || options.fonts.includes("coolemojisp")) { %>
                        <div class="font" data-font="Cool Emojis Pantograph" style="font-family: 'Helvetica';">Cool Emojis</div>
                    <% } %>
                </div>

        <div class="toast"></div>
        <script>
            jQuery(document).ready(function() {
                const demoCollapsible = jQuery(".components-demo-collapsible");
                demoCollapsible.collapsiblepanel();

                const demoModal = jQuery(".components-demo-modal-overlay");
                demoModal.modal();
                jQuery(".components-demo-modal-trigger").click(function() {
                    demoModal.modal("show");
                });
                jQuery(".components-demo-modal-confirm", demoModal).click(function() {
                    demoModal.modal("hide");
                });

                jQuery(".components-demo-toast-trigger").click(function() {
                    jQuery(".toast").toast("show", "Action confirmed.");
                });
            });

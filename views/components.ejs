                        <div class="components-entry-meta-row"><dt>dependencies</dt><dd>js/plugins/modal.js, css/plugins/modal.css</dd></div>
                        <div class="components-entry-meta-row"><dt>since</dt><dd>1.2.0</dd></div>
                    </dl>
                    <script type="application/json" class="components-entry-payload">
                        {
                            "name": "modal-overlay-confirmation",
                            "category": "modal-overlays",
                            "tags": ["overlay", "modal", "confirm"],
                            "dependencies": ["js/plugins/modal.js", "css/plugins/modal.css"],
                            "since": "1.2.0"
                        }
                    </script>
                    <div class="components-entry-preview">
                        <span class="button components-demo-modal-trigger">Open modal</span>
                        <div class="modal-overlay components-demo-modal-overlay">
                            <div class="modal">
                                <div class="modal-title">Confirm action</div>
                                <div class="modal-message">A short description of what is about to happen, written so the operator can review before committing.</div>
                                <div class="modal-buttons">
                                    <span class="button button-ghost button-modal-close">Cancel</span>
                                    <span class="button components-demo-modal-confirm">Confirm</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="components-entry-snippet">
                        <div class="components-entry-snippet-label">HTML</div>
                        <pre class="components-entry-code"><code>&lt;div class=&quot;modal-overlay modal-overlay-example&quot;&gt;
    &lt;div class=&quot;modal&quot;&gt;
        &lt;div class=&quot;modal-title&quot;&gt;Confirm action&lt;/div&gt;
        &lt;div class=&quot;modal-message&quot;&gt;A short description of what is about to happen.&lt;/div&gt;
        &lt;div class=&quot;modal-buttons&quot;&gt;
            &lt;span class=&quot;button button-ghost button-modal-close&quot;&gt;Cancel&lt;/span&gt;
            &lt;span class=&quot;button button-modal-example-confirm&quot;&gt;Confirm&lt;/span&gt;
        &lt;/div&gt;
    &lt;/div&gt;
&lt;/div&gt;</code></pre>
                    </div>
                    <div class="components-entry-snippet">
                        <div class="components-entry-snippet-label">JS</div>
                        <pre class="components-entry-code"><code>const overlay = jQuery(&quot;.modal-overlay-example&quot;);
overlay.modal();
overlay.modal(&quot;show&quot;);
jQuery(&quot;.button-modal-example-confirm&quot;, overlay).click(function() {
    overlay.modal(&quot;hide&quot;);
});</code></pre>
                    </div>
                </article>
            </section>

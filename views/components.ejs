                            "since": "1.0.0"
                        }
                    </script>
                    <div class="components-entry-preview">
                        <div class="components-demo-tabs">
                            <div class="settings-tabs">
                                <span class="settings-tab active" data-tab="first">First</span>
                                <span class="settings-tab" data-tab="second">Second</span>
                                <span class="settings-tab" data-tab="third">Third</span>
                            </div>
                            <div class="settings-tab-content" data-tab="first">Contents of the first tab.</div>
                            <div class="settings-tab-content" data-tab="second" style="display: none;">Contents of the second tab.</div>
                            <div class="settings-tab-content" data-tab="third" style="display: none;">Contents of the third tab.</div>
                        </div>
                    </div>
                    <div class="components-entry-snippet">
                        <div class="components-entry-snippet-label">HTML</div>
                        <pre class="components-entry-code"><code>&lt;div class=&quot;settings-tabs&quot;&gt;
    &lt;span class=&quot;settings-tab active&quot; data-tab=&quot;first&quot;&gt;First&lt;/span&gt;
    &lt;span class=&quot;settings-tab&quot; data-tab=&quot;second&quot;&gt;Second&lt;/span&gt;
&lt;/div&gt;
&lt;div class=&quot;settings-tab-content&quot; data-tab=&quot;first&quot;&gt;Contents of the first tab.&lt;/div&gt;
&lt;div class=&quot;settings-tab-content&quot; data-tab=&quot;second&quot; style=&quot;display: none;&quot;&gt;Contents of the second tab.&lt;/div&gt;</code></pre>
                    </div>
                    <div class="components-entry-snippet">
                        <div class="components-entry-snippet-label">JS</div>
                        <pre class="components-entry-code"><code>const tabs = jQuery(&quot;.settings-tabs &gt; .settings-tab&quot;);
const contents = jQuery(&quot;.settings-tab-content&quot;);
tabs.click(function() {
    const tab = jQuery(this).attr(&quot;data-tab&quot;);
    tabs.removeClass(&quot;active&quot;);
    jQuery(this).addClass(&quot;active&quot;);
    contents.each(function() {
        const content = jQuery(this);
        content.css(&quot;display&quot;, content.attr(&quot;data-tab&quot;) === tab ? &quot;&quot; : &quot;none&quot;);
    });
});</code></pre>
                    </div>
                </article>

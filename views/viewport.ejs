                    <span class="char" data-category="pop" data-value="q">q</span>
                    <span class="char" data-category="pop" data-value="r">r</span>
                    <span class="char" data-category="pop" data-value="s">s</span>
                    <span class="char" data-category="pop" data-value="t">t</span>
                    <span class="char" data-category="pop" data-value="u">u</span>
                    <span class="char" data-category="pop" data-value="v">v</span>
                    <span class="char" data-category="pop" data-value="w">w</span>
                    <span class="char" data-category="pop" data-value="x">x</span>
                    <span class="char" data-category="pop" data-value="y">y</span>
                    <br />
                    <span class="char utility" style="min-width: 66px;">⌫</span>
                    <span class="char utility" style="min-width: 220px;">⎵</span>
                    <span class="char utility" style="min-width: 66px;">↵</span>
                </div>
            </div>
        </div>
        <div class="toast"></div>
        <div class="modal-overlay modal-overlay-confirm"
             data-label-text="Text"
             data-label-font="Font"
             data-label-profile="Profile"
             data-label-viewport="Surface"
             data-label-font-size="Size"
             data-label-margins="Margins"
             data-label-extra-padding="Ext. Pad."
             data-label-final-viewport="Final"
             data-label-node="Node"
             data-label-jig="Jig"
             data-label-newline="↵"
             data-label-empty="No text yet — type something on the viewport first."
             data-label-ready="Ready to engrave on">
            <div class="modal modal-confirm">
                <div class="modal-title">Confirm Engraving</div>
                <div class="modal-subtitle"></div>
                <div class="modal-preview"></div>
                <div class="modal-empty-hint"></div>
                <div class="modal-specs"></div>
                <div class="modal-options">
                    <input class="modal-dry-run option-chip-input" type="checkbox" id="modal-dry-run" />
                    <label class="option-chip option-chip-toggle" for="modal-dry-run">Dry run</label>
                </div>
                <div class="modal-buttons">
                    <span class="button button-modal-engrave">Engrave</span>
                    <span class="button button-ghost button-modal-close">Cancel</span>
                </div>
            </div>
        </div>
        <div class="modal-overlay modal-overlay-error">
            <div class="modal">
                <div class="modal-message"></div>
                <div class="modal-buttons">
                    <a class="button button-modal-configure" href="/settings">Configure</a>
                    <span class="button button-modal-close">Close</span>
                </div>
            </div>
        </div>
        <div class="modal-overlay modal-overlay-inspirations">
            <div class="modal modal-inspirations">
                <div class="modal-title">Inspirations</div>
                <div class="modal-search">
                    <input class="modal-search-input" type="text" placeholder="Search inspirations..." />
                </div>
                <div class="modal-inspirations-grid"></div>
                <div class="modal-buttons">
                    <span class="button button-modal-close">Close</span>
                </div>
            </div>
        </div>
        <div class="modal-overlay modal-overlay-instructions">
            <div class="modal modal-instructions">
                <div class="modal-title modal-instructions-title"></div>
                <div class="modal-message modal-instructions-description"></div>
                <div class="modal-instructions-images"></div>
                <div class="modal-buttons">
                    <span class="button button-modal-close">Close</span>
                </div>
            </div>
        </div>
    </body>
</html>

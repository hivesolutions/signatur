<!DOCTYPE html>
<html lang="pt">
    <%- include("head"); -%>
    <body class="<%= theme %>" data-theme="<%= theme %>">
        <div class="welcome">
            <form class="form form-settings" method="post" action="/settings">
                <div class="welcome-hero">
                    <div class="welcome-hero-mark">
                        <% if (theme === "ldj") { %>
                            <img class="logo" src="/static/images/logo.svg" />
                        <% } else { %>
                            <span class="logo">Signatur</span>
                        <% } %>
                    </div>
                    <div class="welcome-hero-eyebrow">Definições</div>
                    <div class="welcome-hero-divider"></div>
                </div>
                <div class="welcome-catalog">
                    <div class="settings-tabs">
                        <span class="settings-tab active" data-tab="general">Geral</span>
                        <span class="settings-tab" data-tab="printing">Impressão</span>
                        <span class="settings-tab" data-tab="features">Funcionalidades</span>
                        <span class="settings-tab" data-tab="emojis">Emojis</span>
                        <span class="settings-tab" data-tab="diagnostics">Diagnóstico</span>
                    </div>
                    <div class="settings-container settings-tab-content" data-tab="general">
                        <div class="settings-group">
                            <div class="settings-group-label">Tema</div>
                            <div class="option-chips" id="theme-options">
                                <input class="option-chip-input" type="radio" id="theme-default" name="theme" value=""
                                    <%= !theme ? "checked" : '' %>>
                                <label class="option-chip" for="theme-default">Predefinido</label>
                                <input class="option-chip-input" type="radio" id="theme-ldj" name="theme" value="ldj"
                                    <%= theme === "ldj" ? "checked" : '' %>>
                                <label class="option-chip" for="theme-ldj">Lugar da Joia</label>
                            </div>
                        </div>
                        <div class="settings-group">
                            <div class="settings-group-label">Idioma</div>
                            <div class="option-chips" id="locale-options">
                                <input class="option-chip-input" type="radio" id="locale-default" name="locale" value=""
                                    <%= !locale ? "checked" : '' %>>
                                <label class="option-chip" for="locale-default">English</label>
                                <input class="option-chip-input" type="radio" id="locale-pt-pt" name="locale" value="pt_pt"
                                    <%= locale === "pt_pt" ? "checked" : '' %>>
                                <label class="option-chip" for="locale-pt-pt">Português</label>
                            </div>
                        </div>
                        <div class="settings-group">
                            <div class="settings-group-label">Ecrã Inteiro</div>
                            <div class="option-chips" id="fullscreen-options">
                                <input class="option-chip-input" type="radio" id="fullscreen-off" name="fullscreen" value="0"
                                    <%= !fullscreen ? "checked" : '' %>>
                                <label class="option-chip" for="fullscreen-off">Desligado</label>
                                <input class="option-chip-input" type="radio" id="fullscreen-on" name="fullscreen" value="1"
                                    <%= fullscreen ? "checked" : '' %>>
                                <label class="option-chip" for="fullscreen-on">Ligado</label>
                            </div>
                        </div>
                        <div class="settings-group">
                            <div class="settings-group-label">Página Inicial</div>
                            <div class="option-chips" id="home-options">
                                <input class="option-chip-input" type="radio" id="home-gateway" name="home" value="gateway"
                                    <%= home !== "welcome" ? "checked" : '' %>>
                                <label class="option-chip" for="home-gateway">Entrada</label>
                                <input class="option-chip-input" type="radio" id="home-welcome" name="home" value="welcome"
                                    <%= home === "welcome" ? "checked" : '' %>>
                                <label class="option-chip" for="home-welcome">Boas-vindas</label>
                            </div>
                        </div>
                        <div class="settings-group">
                            <div class="settings-group-label">Mostrar Opções</div>
                            <div class="option-chips" id="show-options">
                                <input class="option-chip-input" type="radio" id="show-options-on" name="show_options" value="1"
                                    <%= showOptions ? "checked" : '' %>>
                                <label class="option-chip" for="show-options-on">Ligado</label>
                                <input class="option-chip-input" type="radio" id="show-options-off" name="show_options" value="0"
                                    <%= !showOptions ? "checked" : '' %>>
                                <label class="option-chip" for="show-options-off">Desligado</label>
                            </div>
                        </div>
                        <div class="settings-group">
                            <div class="settings-group-label">Modo do Viewport</div>
                            <div class="option-chips" id="viewport-mode-options">
                                <input class="option-chip-input" type="radio" id="viewport-mode-technical" name="viewport_mode" value="technical"
                                    <%= viewportMode !== "store" ? "checked" : '' %>>
                                <label class="option-chip" for="viewport-mode-technical">Técnico</label>
                                <input class="option-chip-input" type="radio" id="viewport-mode-store" name="viewport_mode" value="store"
                                    <%= viewportMode === "store" ? "checked" : '' %>>
                                <label class="option-chip" for="viewport-mode-store">Loja</label>
                            </div>
                        </div>
                        <div class="settings-group">
                            <div class="settings-group-label">Versão</div>
                            <div class="settings-readout"><%= info.version %></div>
                        </div>
                    </div>
                    <div class="settings-container settings-tab-content" data-tab="printing" style="display: none;">
                        <div class="settings-printing">
                            <div class="settings-printing-row" data-key="url">
                                <div class="settings-printing-label">URL</div>
                                <div class="settings-printing-sub">
                                    <div class="settings-printing-sub-label">Base</div>
                                    <input class="settings-printing-base" type="text"
                                           value="<%= conf.PRINT_URL || "-" %>" disabled />
                                </div>
                                <div class="settings-printing-sub">
                                    <div class="settings-printing-sub-label">Efectivo</div>
                                    <input class="settings-printing-effective" type="text"
                                           placeholder="<%= conf.PRINT_URL || "" %>" />
                                </div>
                            </div>
                            <div class="settings-printing-row" data-key="engrave_node" data-legacy="node">
                                <div class="settings-printing-label">Node de Gravação</div>
                                <div class="settings-printing-sub">
                                    <div class="settings-printing-sub-label">Base</div>
                                    <input class="settings-printing-base" type="text"
                                           value="<%= conf.ENGRAVE_NODE || "-" %>" disabled />
                                </div>
                                <div class="settings-printing-sub">
                                    <div class="settings-printing-sub-label">Efectivo</div>
                                    <input class="settings-printing-effective" type="text"
                                           placeholder="<%= conf.ENGRAVE_NODE || "" %>" />
                                </div>
                            </div>
                            <div class="settings-printing-row" data-key="engrave_printer" data-legacy="printer">
                                <div class="settings-printing-label">Impressora de Gravação</div>
                                <div class="settings-printing-sub">
                                    <div class="settings-printing-sub-label">Base</div>
                                    <input class="settings-printing-base" type="text"
                                           value="<%= conf.ENGRAVE_PRINTER || "-" %>" disabled />
                                </div>
                                <div class="settings-printing-sub">
                                    <div class="settings-printing-sub-label">Efectivo</div>
                                    <input class="settings-printing-effective" type="text"
                                           placeholder="<%= conf.ENGRAVE_PRINTER || "" %>" />
                                </div>
                            </div>
                            <div class="settings-printing-row" data-key="receipt_node" data-legacy="node">
                                <div class="settings-printing-label">Node do Recibo</div>
                                <div class="settings-printing-sub">
                                    <div class="settings-printing-sub-label">Base</div>
                                    <input class="settings-printing-base" type="text"
                                           value="<%= conf.PRINT_NODE || "-" %>" disabled />
                                </div>
                                <div class="settings-printing-sub">
                                    <div class="settings-printing-sub-label">Efectivo</div>
                                    <input class="settings-printing-effective" type="text"
                                           placeholder="<%= conf.PRINT_NODE || "" %>" />
                                </div>
                            </div>
                            <div class="settings-printing-row" data-key="receipt_printer" data-legacy="printer">
                                <div class="settings-printing-label">Impressora do Recibo</div>
                                <div class="settings-printing-sub">
                                    <div class="settings-printing-sub-label">Base</div>
                                    <input class="settings-printing-base" type="text"
                                           value="<%= conf.PRINT_PRINTER || "-" %>" disabled />
                                </div>
                                <div class="settings-printing-sub">
                                    <div class="settings-printing-sub-label">Efectivo</div>
                                    <input class="settings-printing-effective" type="text"
                                           placeholder="<%= conf.PRINT_PRINTER || "" %>" />
                                </div>
                            </div>
                            <div class="settings-printing-row" data-key="key" data-secret="1">
                                <div class="settings-printing-label">Chave</div>
                                <div class="settings-printing-sub">
                                    <div class="settings-printing-sub-label">Base</div>
                                    <input class="settings-printing-base" type="text"
                                           value="<%= conf.PRINT_KEY ? "(definido)" : "-" %>" disabled />
                                </div>
                                <div class="settings-printing-sub">
                                    <div class="settings-printing-sub-label">Efectivo</div>
                                    <input class="settings-printing-effective" type="text"
                                           placeholder="<%= conf.PRINT_KEY ? "(definido)" : "" %>" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="settings-container settings-tab-content" data-tab="features" style="display: none;">
                        <div class="settings-features">
                            <% Object.keys(features).forEach(function(name) { %>
                                <div class="settings-features-row" data-key="<%= name %>">
                                    <div class="settings-features-label"><%= name %></div>
                                    <div class="settings-features-sub">
                                        <div class="settings-features-sub-label">Base</div>
                                        <input class="settings-features-base" type="text"
                                               value="<%= featuresBase[name] ? "Ligado" : "Desligado" %>" disabled />
                                    </div>
                                    <div class="settings-features-sub">
                                        <div class="settings-features-sub-label">Efectivo</div>
                                        <div class="option-chips">
                                            <input class="option-chip-input" type="radio"
                                                   id="feature-<%= name %>-default"
                                                   name="feature_<%= name %>" value=""
                                                <%= featuresOverride[name] === undefined ? "checked" : '' %>>
                                            <label class="option-chip" for="feature-<%= name %>-default">Predefinição</label>
                                            <input class="option-chip-input" type="radio"
                                                   id="feature-<%= name %>-off"
                                                   name="feature_<%= name %>" value="0"
                                                <%= featuresOverride[name] === "0" ? "checked" : '' %>>
                                            <label class="option-chip" for="feature-<%= name %>-off">Desligado</label>
                                            <input class="option-chip-input" type="radio"
                                                   id="feature-<%= name %>-on"
                                                   name="feature_<%= name %>" value="1"
                                                <%= featuresOverride[name] === "1" ? "checked" : '' %>>
                                            <label class="option-chip" for="feature-<%= name %>-on">Ligado</label>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                    <div class="settings-container settings-tab-content" data-tab="emojis" style="display: none;"
                         data-label-upload="Carregar"
                         data-label-uploading="A carregar…"
                         data-label-font-required="Escolha um ficheiro TTF antes de carregar."
                         data-label-success="Letra Cool Emojis carregada com sucesso."
                         data-label-network-error="O pedido de carregamento falhou. O servidor pode estar inacessível.">
                        <div class="settings-group">
                            <div class="settings-group-label">Cool Emojis</div>
                            <div class="emojis-hint">Substitui a letra <code>coolemojis.ttf</code> incluída e, opcionalmente, o ficheiro <code>coolemojis.mapping.json</code> companheiro pelos ficheiros carregados. A próxima abertura do editor já mostra os novos glifos.</div>
                            <div class="emojis-field">
                                <label class="emojis-field-label" for="emojis-font">Letra (.ttf)</label>
                                <input class="emojis-field-input" id="emojis-font" type="file" accept=".ttf,.otf" />
                            </div>
                            <div class="emojis-field">
                                <label class="emojis-field-label" for="emojis-mapping">Mapeamento (.json, opcional)</label>
                                <input class="emojis-field-input" id="emojis-mapping" type="file" accept="application/json,.json" />
                            </div>
                            <div class="emojis-actions">
                                <button type="button" class="button button-start emojis-upload">Carregar</button>
                            </div>
                            <div class="emojis-feedback" hidden></div>
                        </div>
                    </div>
                    <div class="settings-container settings-tab-content" data-tab="diagnostics" style="display: none;"
                         data-label-tools="Ferramentas"
                         data-label-pipeline="Pipeline"
                         data-label-run="Executar diagnóstico"
                         data-label-running="A executar…"
                         data-label-pass="OK"
                         data-label-fail="Falhou"
                         data-label-empty="Carregue em Executar diagnóstico para verificar o Inkscape, Ghostscript e pstoedit, e executar o pipeline de gravação sobre um ficheiro de teste incluído."
                         data-label-network-error="O pedido de diagnóstico falhou. O servidor pode estar inacessível.">
                        <div class="settings-group">
                            <div class="settings-group-label">Diagnóstico</div>
                            <div class="diagnostics-hint">Sonda as ferramentas do pipeline de gravação e corre o ficheiro <code>res/diagnostic.svg</code> através de toda a cadeia SVG → PDF → PS → HPGL.</div>
                            <div class="diagnostics-actions">
                                <button type="button" class="button button-start diagnostics-run">Executar diagnóstico</button>
                            </div>
                            <div class="diagnostics-empty">Carregue em Executar diagnóstico para verificar o Inkscape, Ghostscript e pstoedit, e executar o pipeline de gravação sobre um ficheiro de teste incluído.</div>
                            <div class="diagnostics-section diagnostics-probes" hidden>
                                <div class="diagnostics-section-title">Ferramentas</div>
                                <div class="diagnostics-probe-list"></div>
                            </div>
                            <div class="diagnostics-section diagnostics-pipeline" hidden>
                                <div class="diagnostics-section-title">Pipeline</div>
                                <div class="diagnostics-step-list"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <input type="hidden" name="next" value="<%= next ? next : '' %>" />
                <div class="welcome-action-bar">
                    <div class="welcome-options"></div>
                    <div class="welcome-actions">
                        <a class="button button-ghost button-cancel" href="<%= next ? next : '/' %>">Voltar</a>
                        <button type="submit" class="button button-start">Guardar</button>
                    </div>
                </div>
            </form>
        </div>
    </body>
</html>
